# ============================================================================
# SGTI — Environment Variables Reference
# ============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file with real values to the repository.
#
# For Vercel: set these in the Vercel Dashboard → Project → Settings → Environment Variables
# For GitHub Actions: set these in Settings → Secrets and Variables → Actions
# ============================================================================

# ─── Next.js ─────────────────────────────────────────────────────────────────
# These NEXT_PUBLIC_ vars are exposed to the browser — use only non-secret values.
NEXT_PUBLIC_APP_VERSION=0.1.0

# ─── Supabase (DEV) ──────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service Role key — NEVER expose to the browser. Server-only.
# Used by: Admin operations, Edge Functions, Server Actions that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Direct database URL for migrations (bypasses PgBouncer connection pooler).
# Found in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Created in: Google Cloud Console → APIs & Services → Credentials
# OAuth 2.0 Client ID and Secret for Google Workspace SSO.
# Configured in: Supabase Dashboard → Authentication → Providers → Google
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-oauth-client-secret>

# Restrict OAuth login to this domain only (e.g., "pinpag.com.br")
# Enforced via Supabase Auth hook (see supabase/functions/auth-hook-domain/)
GOOGLE_ALLOWED_DOMAIN=pinpag.com.br

# ─── Vercel ───────────────────────────────────────────────────────────────────
# Used by: GitHub Actions CD pipeline for Vercel CLI deploy
# Found in: Vercel Dashboard → Team Settings → General (Org ID)
#            Vercel Dashboard → Project Settings → General (Project ID)
VERCEL_TOKEN=<your-vercel-personal-access-token>
VERCEL_ORG_ID=<your-vercel-org-id>
VERCEL_PROJECT_ID=<your-vercel-project-id>

# ─── App configuration ────────────────────────────────────────────────────────
# The public URL of the SGTI frontend (used for redirect allow-list, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Edge Functions ───────────────────────────────────────────────────────────
# Secret for authenticating cron-triggered Edge Function calls.
# Generate with: openssl rand -hex 32
CRON_SECRET=<generate-with-openssl-rand-hex-32>

# ─── Integrations (Phase 10+) ─────────────────────────────────────────────────
# These are not needed for Sprint 0 — added here for reference.

# GLPI REST API
# GLPI_API_URL=https://glpi.your-domain.com/api
# GLPI_APP_TOKEN=<your-glpi-app-token>
# GLPI_USER_TOKEN=<your-glpi-user-token>

# Google Workspace Admin SDK (IAM integration — Phase 12)
# GOOGLE_ADMIN_EMAIL=admin@pinpag.com.br
# GOOGLE_SERVICE_ACCOUNT_KEY=<base64-encoded-service-account-json>

# ─── Vercel-injected (read-only, available automatically in Vercel runtime) ───
# These are set by Vercel automatically — do not set them manually.
# VERCEL=1
# VERCEL_ENV=development|preview|production
# VERCEL_URL=<deployment-url>
# VERCEL_GIT_COMMIT_SHA=<commit-sha>
# VERCEL_DEPLOYMENT_ID=<deployment-id>
